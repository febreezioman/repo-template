.ipynb_checkpoints/
*.pyc
__pycache__/

# Quarto
.quarto/
slides/*_files/

# Papers — track notes/index but not binary files
# To version PDFs, use git-lfs: git lfs track "papers/**/*.pdf"
papers/**/*.pdf
papers/**/*.PDF
papers/**/*.docx
papers/**/*.xlsx
papers/**/*.pptx
papers/**/*.zip

# OS
.DS_Store
Thumbs.db

