# Raw input data — store externally, never commit
raw/*
!raw/.gitkeep

# Pipeline output (e.g., aligners, callers)
out/*
!out/.gitkeep

# Intermediate analysis files
processing/*
!processing/.gitkeep

# Reference data (genome, indices)
refs/*
!refs/.gitkeep

# Old/scratch work
Archive/
scratch/

# Sequencing / common large files
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.bam.bai
*.sam
*.vcf
*.vcf.gz
*.bcf
*.bed
*.bigwig
*.bw
*.bigbed
*.h5ad
*.loom
*.zip

# Conda environments (track .yml files, not installed env dirs)
envs/*/

# Jupyter
.ipynb_checkpoints/
*.pyc
__pycache__/

# Quarto
.quarto/
docs/slides/*_files/
docs/slides/presentation.aux
docs/slides/presentation.log
docs/slides/presentation.tex
docs/draft/*_files/

# Claude Code
.claude/

# Papers — track notes/index but not binary files
# To version PDFs, use git-lfs: git lfs track "papers/**/*.pdf"
papers/**/*.pdf
papers/**/*.PDF
papers/**/*.docx
papers/**/*.xlsx
papers/**/*.pptx
papers/**/*.zip

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*~
